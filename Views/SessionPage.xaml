<Page x:Class="JulesClient.Views.SessionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:JulesClient.Models"
    xmlns:vm="using:JulesClient.ViewModels"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sessions List -->
        <Grid Grid.Column="0" BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}" BorderThickness="0,0,1,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Padding="12" Spacing="10">
                <TextBlock Text="Sessions" Style="{StaticResource TitleTextBlockStyle}"/>
                <Button Command="{x:Bind ViewModel.LoadSessionsCommand}">
                    <Button.Icon>
                        <SymbolIcon Symbol="Refresh"/>
                    </Button.Icon>
                </Button>
            </StackPanel>

            <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Sessions}"
                      SelectedItem="{x:Bind ViewModel.SelectedSession, Mode=TwoWay}">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:Session">
                        <StackPanel Padding="12">
                            <TextBlock Text="{x:Bind Prompt}" Style="{StaticResource BodyStrongTextBlockStyle}" MaxLines="1" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{x:Bind State}" Style="{StaticResource CaptionTextBlockStyle}"/>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- Session Detail / Chat -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Select a session to start"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="{x:Bind ViewModel.SelectedSession, Mode=OneWay, Converter={StaticResource InvertedNullToVisibilityConverter}}"
                       Style="{StaticResource TitleTextBlockStyle}"/>

            <Grid Grid.Row="0" Visibility="{x:Bind ViewModel.SelectedSession, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Padding="12" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}" Spacing="10">
                    <TextBlock Text="{x:Bind ViewModel.SelectedSession.Prompt, Mode=OneWay}" Style="{StaticResource SubtitleTextBlockStyle}" MaxLines="2"/>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                         <TextBlock Text="State:" Style="{StaticResource CaptionTextBlockStyle}"/>
                         <TextBlock Text="{x:Bind ViewModel.SelectedSession.State, Mode=OneWay}" Style="{StaticResource CaptionTextBlockStyle}" FontWeight="Bold"/>
                         <Button Content="Approve Plan"
                                 Visibility="{x:Bind ViewModel.SelectedSession.PendingPlan, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"
                                 Command="{x:Bind ViewModel.ApprovePlanCommand}"
                                 Style="{StaticResource AccentButtonStyle}"
                                 Padding="12,4"/>
                    </StackPanel>
                </StackPanel>

                <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Activities}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:Activity">
                            <Grid Padding="12">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Bind Originator}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>

                                    <!-- Progress Updated -->
                                    <StackPanel Visibility="{x:Bind ProgressUpdated, Converter={StaticResource NullToVisibilityConverter}}">
                                        <TextBlock Text="{x:Bind ProgressUpdated.Title}" FontWeight="Bold"/>
                                        <TextBlock Text="{x:Bind ProgressUpdated.Description}" TextWrapping="WrapWholeWords"/>
                                    </StackPanel>

                                    <!-- Plan Generated -->
                                    <StackPanel Visibility="{x:Bind PlanGenerated, Converter={StaticResource NullToVisibilityConverter}}">
                                        <TextBlock Text="Plan Generated" FontWeight="Bold"/>
                                        <TextBlock Text="{x:Bind PlanGenerated.Plan.Title}" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                        <TextBlock Text="{x:Bind PlanGenerated.Plan.Description}" TextWrapping="WrapWholeWords"/>
                                    </StackPanel>

                                    <!-- Artifacts (Simplified) -->
                                    <ItemsControl ItemsSource="{x:Bind Artifacts}" Visibility="{x:Bind Artifacts, Converter={StaticResource NullToVisibilityConverter}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:Artifact">
                                                <StackPanel Margin="0,4">
                                                    <TextBlock Text="[Artifact]" FontStyle="Italic" Style="{StaticResource CaptionTextBlockStyle}"/>
                                                    <TextBlock Text="{x:Bind BashOutput.Output}" Visibility="{x:Bind BashOutput, Converter={StaticResource NullToVisibilityConverter}}"
                                                               FontFamily="Consolas" FontSize="12" TextWrapping="Wrap"/>
                                                    <TextBlock Text="Change Set Applied" Visibility="{x:Bind ChangeSet, Converter={StaticResource NullToVisibilityConverter}}"
                                                               FontWeight="Bold"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <!-- Chat Input -->
            <Grid Grid.Row="1" Padding="20" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                  Visibility="{x:Bind ViewModel.SelectedSession, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" PlaceholderText="Type a message..."
                         Text="{x:Bind ViewModel.ChatInput, Mode=TwoWay}"
                         AcceptsReturn="True" MaxHeight="100"/>
                <Button Grid.Column="1" Content="Send" Margin="12,0,0,0" VerticalAlignment="Bottom"
                        Command="{x:Bind ViewModel.SendMessageCommand}"/>
            </Grid>
        </Grid>
    </Grid>
</Page>

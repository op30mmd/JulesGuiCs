<Page x:Class="JulesClient.Views.SessionsPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:JulesClient.Models"
    xmlns:vm="using:JulesClient.ViewModels"
    xmlns:converters="using:JulesClient.Services"
    xmlns:svc="using:JulesClient.Services"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <Style x:Key="SessionItemStyle" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="2,2,2,2"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <ListViewItemPresenter
                            ContentTransitions="{TemplateBinding ContentTransitions}"
                            SelectionCheckMarkVisualEnabled="False"
                            CheckMode="Inline"
                            ContentMargin="{TemplateBinding Padding}"
                            Control.IsTemplateFocusTarget="True"
                            FocusVisualMargin="0"
                            PointerOverBackground="{ThemeResource SystemControlHighlightListLowBrush}"
                            SelectedBackground="{ThemeResource SystemControlHighlightListAccentLowBrush}"
                            SelectedPointerOverBackground="{ThemeResource SystemControlHighlightListAccentMediumBrush}"
                            PressedBackground="{ThemeResource SystemControlHighlightListMediumBrush}"
                            SelectedPressedBackground="{ThemeResource SystemControlHighlightListAccentHighBrush}"
                            CornerRadius="{TemplateBinding CornerRadius}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <converters:OriginatorToAlignmentConverter x:Key="OriginatorToAlignmentConverter"/>
        <converters:OriginatorToColorConverter x:Key="OriginatorToColorConverter"/>
        <converters:OriginatorToMaxWidthConverter x:Key="OriginatorToMaxWidthConverter"/>
        <converters:OriginatorToBorderThicknessConverter x:Key="OriginatorToBorderThicknessConverter"/>
        <converters:OriginatorToBorderBrushConverter x:Key="OriginatorToBorderBrushConverter"/>
        <converters:Base64ToImageSourceConverter x:Key="Base64ToImageSourceConverter"/>
        <converters:InvertedNullToVisibilityConverter x:Key="InvertedNullToVisibilityConverter"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <converters:CollectionToVisibilityConverter x:Key="CollectionToVisibilityConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <converters:StringToBooleanConverter x:Key="StringToBooleanConverter"/>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converters:InvertedBooleanToVisibilityConverter x:Key="InvertedBooleanToVisibilityConverter"/>
        <converters:DiffLineTypeToColorConverter x:Key="DiffLineTypeToColorConverter"/>
        <converters:DiffLineTypeToForegroundConverter x:Key="DiffLineTypeToForegroundConverter"/>
        <converters:DiffLineTypeToFontWeightConverter x:Key="DiffLineTypeToFontWeightConverter"/>
        <converters:DiffPrefixConverter x:Key="DiffPrefixConverter"/>

        <DataTemplate x:Key="ArtifactsTemplate" x:DataType="models:Artifact">
            <StackPanel Margin="0,1,0,0">
                <!-- Bash Output: Minimalist rendering -->
                <StackPanel Margin="0,1" Padding="8,4" Background="{ThemeResource SystemControlBackgroundBaseLowBrush}" CornerRadius="4"
                            Visibility="{x:Bind BashOutput.HasData, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                    <TextBlock Text="{x:Bind BashOutput.Output, Mode=OneWay}" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" Opacity="0.9"/>
                </StackPanel>

                <!-- Pull Request: Single-line hyperlink -->
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,1"
                            Visibility="{x:Bind PullRequest.HasData, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                    <SymbolIcon Symbol="Link" Foreground="{ThemeResource SystemAccentColor}" Width="16" Height="16"/>
                    <HyperlinkButton Content="{x:Bind PullRequest.Title, Mode=OneWay}" NavigateUri="{x:Bind PullRequest.Url, Mode=OneWay}" Padding="0" FontSize="12" FontWeight="SemiBold"/>
                </StackPanel>

                <!-- Media: Compact scale -->
                <Image Source="{x:Bind Media.Data, Converter={StaticResource Base64ToImageSourceConverter}, Mode=OneWay}"
                        Visibility="{x:Bind Media.HasData, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}"
                        MaxHeight="250" Stretch="Uniform" Margin="0,2" HorizontalAlignment="Left"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="DefaultMessageTemplate" x:DataType="models:Activity">
            <Grid Margin="16,1" Visibility="{x:Bind HasContent, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                <Border CornerRadius="12" Padding="12,10"
                        HorizontalAlignment="{x:Bind EffectiveOriginator, Converter={StaticResource OriginatorToAlignmentConverter}}"
                        Background="{x:Bind EffectiveOriginator, Converter={StaticResource OriginatorToColorConverter}}"
                        MaxWidth="{x:Bind EffectiveOriginator, Converter={StaticResource OriginatorToMaxWidthConverter}}"
                        BorderThickness="{x:Bind EffectiveOriginator, Converter={StaticResource OriginatorToBorderThicknessConverter}}"
                        BorderBrush="{x:Bind EffectiveOriginator, Converter={StaticResource OriginatorToBorderBrushConverter}}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="{x:Bind EffectiveOriginator}" Style="{StaticResource CaptionTextBlockStyle}" FontWeight="Bold" Opacity="0.5" Margin="0,0,0,1" FontSize="11"/>

                        <TextBlock converters:MarkdownHelper.Text="{x:Bind DisplayText, Mode=OneWay}"
                                   TextWrapping="WrapWholeWords" FontSize="14" LineHeight="20" LineStackingStrategy="MaxHeight"
                                   Visibility="{x:Bind DisplayText, Converter={StaticResource StringToVisibilityConverter}, Mode=OneWay}"/>


                        <StackPanel Margin="0,1" Visibility="{x:Bind ShowProgressBlock, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                            <TextBlock Text="{x:Bind ProgressUpdated.Title, Mode=OneWay}" FontWeight="Bold" TextWrapping="WrapWholeWords" FontSize="14" LineHeight="20" LineStackingStrategy="MaxHeight"
                                       Visibility="{x:Bind ProgressUpdated.Title, Converter={StaticResource StringToVisibilityConverter}, Mode=OneWay}"/>
                            <TextBlock converters:MarkdownHelper.Text="{x:Bind ProgressUpdated.Description, Mode=OneWay}"
                                       TextWrapping="WrapWholeWords" Opacity="0.9" FontSize="14" LineHeight="20" LineStackingStrategy="MaxHeight"
                                       Visibility="{x:Bind ProgressUpdated.Description, Converter={StaticResource StringToVisibilityConverter}, Mode=OneWay}"/>
                        </StackPanel>

                        <StackPanel Margin="0,1" Visibility="{x:Bind ShowPlan, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                            <TextBlock Text="Proposed Plan" FontWeight="Bold" Foreground="{ThemeResource SystemAccentColor}" FontSize="13" Opacity="0.8" LineHeight="20" LineStackingStrategy="MaxHeight"/>
                            <TextBlock Text="{x:Bind PlanGenerated.Plan.Title, Mode=OneWay}" Style="{StaticResource BodyStrongTextBlockStyle}" FontSize="14" LineHeight="20" LineStackingStrategy="MaxHeight"
                                       Visibility="{x:Bind PlanGenerated.Plan.Title, Converter={StaticResource StringToVisibilityConverter}, Mode=OneWay}"/>
                            <TextBlock converters:MarkdownHelper.Text="{x:Bind PlanGenerated.Plan.Description, Mode=OneWay}" TextWrapping="WrapWholeWords" Opacity="0.9" FontSize="14" LineHeight="20" LineStackingStrategy="MaxHeight"
                                       Visibility="{x:Bind PlanGenerated.Plan.Description, Converter={StaticResource StringToVisibilityConverter}, Mode=OneWay}"/>

                            <ItemsControl ItemsSource="{x:Bind PlanGenerated.Plan.Steps, Mode=OneWay}" Margin="0,4,0,0"
                                          Visibility="{x:Bind PlanGenerated.Plan.Steps, Converter={StaticResource CollectionToVisibilityConverter}, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:PlanStep">
                                        <StackPanel Margin="0,2" Spacing="0">
                                            <TextBlock Text="{x:Bind Title, Mode=OneWay}" FontWeight="SemiBold" FontSize="13" LineHeight="20" LineStackingStrategy="MaxHeight"/>
                                            <TextBlock converters:MarkdownHelper.Text="{x:Bind Description, Mode=OneWay}" FontSize="12" Opacity="0.8" LineHeight="20" LineStackingStrategy="MaxHeight"
                                                       Visibility="{x:Bind Description, Converter={StaticResource StringToVisibilityConverter}, Mode=OneWay}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <Border Margin="0,2" Padding="12" CornerRadius="8" Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}" BorderBrush="{ThemeResource SystemFillColorCriticalBrush}" BorderThickness="1"
                                Visibility="{x:Bind SessionFailed, Converter={StaticResource NullToVisibilityConverter}, Mode=OneWay}">
                           <StackPanel Orientation="Horizontal" Spacing="12">
                               <SymbolIcon Symbol="Important" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                               <StackPanel>
                                   <TextBlock Text="Session Failed" FontWeight="Bold" Foreground="{ThemeResource SystemFillColorCriticalBrush}" FontSize="14" LineHeight="20" LineStackingStrategy="MaxHeight"/>
                                   <TextBlock Text="{x:Bind SessionFailed.Reason, Mode=OneWay}" TextWrapping="Wrap" FontSize="13" Opacity="0.9" LineHeight="20" LineStackingStrategy="MaxHeight"
                                              Visibility="{x:Bind SessionFailed.Reason, Converter={StaticResource StringToVisibilityConverter}, Mode=OneWay}"/>
                               </StackPanel>
                           </StackPanel>
                       </Border>

                        <!-- All artifacts now rendered via this ItemsControl for consistency and deduplication -->
                        <ItemsControl ItemsSource="{x:Bind Artifacts, Mode=OneWay}" ItemTemplate="{StaticResource ArtifactsTemplate}" HorizontalContentAlignment="Stretch" Visibility="{x:Bind Artifacts, Converter={StaticResource CollectionToVisibilityConverter}, Mode=OneWay}"/>

                        <TextBlock Text="{x:Bind CreateTime, Mode=OneWay}" Style="{StaticResource CaptionTextBlockStyle}" HorizontalAlignment="Right" Opacity="0.4" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="CodeReviewTemplate" x:DataType="models:Activity">
            <Grid Margin="16,6" Visibility="{x:Bind HasContent, Converter={StaticResource BooleanToVisibilityConverter}, Mode=OneWay}">
                <Border CornerRadius="8" Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource SystemAccentColor}"
                        BorderThickness="1"
                        HorizontalAlignment="Stretch">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border Background="{ThemeResource SystemAccentColor}" Padding="8,4" CornerRadius="4">
                                <TextBlock Text="CODE REVIEW" FontSize="11" FontWeight="Bold" Foreground="White"/>
                            </Border>
                            <TextBlock Text="{x:Bind ReviewDisplayTitle, Mode=OneWay}" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" LineHeight="20" LineStackingStrategy="MaxHeight"/>
                        </StackPanel>

                        <TextBlock converters:MarkdownHelper.Text="{x:Bind ReviewDisplayText, Mode=OneWay}" TextWrapping="WrapWholeWords" FontSize="14" LineHeight="20" LineStackingStrategy="MaxHeight"
                                   Visibility="{x:Bind ReviewDisplayText, Converter={StaticResource StringToVisibilityConverter}, Mode=OneWay}"/>

                        <ItemsControl ItemsSource="{x:Bind Review.Comments, Mode=OneWay}" Visibility="{x:Bind Review.Comments, Converter={StaticResource CollectionToVisibilityConverter}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:ReviewComment">
                                    <StackPanel Margin="0,4" Padding="12" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}" CornerRadius="6" BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}" BorderThickness="1">
                                        <TextBlock FontWeight="SemiBold" FontSize="12" Opacity="0.8" Foreground="{ThemeResource SystemAccentColor}" LineHeight="20" LineStackingStrategy="MaxHeight">
                                            <Run Text="{x:Bind FilePath}"/>
                                            <Run Text=" : "/>
                                            <Run Text="{x:Bind LineNumber}"/>
                                        </TextBlock>
                                        <TextBlock converters:MarkdownHelper.Text="{x:Bind Comment}" TextWrapping="Wrap" FontSize="13" Margin="0,4,0,0" LineHeight="20" LineStackingStrategy="MaxHeight"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>


                        <TextBlock Text="{x:Bind CreateTime, Mode=OneWay}" Style="{StaticResource CaptionTextBlockStyle}" HorizontalAlignment="Right" Opacity="0.4" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>

        <svc:ChatActivityTemplateSelector x:Key="ChatActivityTemplateSelector"
            DefaultMessageTemplate="{StaticResource DefaultMessageTemplate}"
            CodeReviewTemplate="{StaticResource CodeReviewTemplate}"/>

        <DataTemplate x:Key="DiffDisplayItemTemplate" x:DataType="svc:DiffDisplayItem">
            <Grid Background="{x:Bind Type, Converter={StaticResource DiffLineTypeToColorConverter}}" Padding="2,1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="40"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{x:Bind OldLineNumber}" FontFamily="Consolas" FontSize="11" Opacity="0.5" HorizontalAlignment="Right" VerticalAlignment="Center" Padding="0,0,6,0" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock Grid.Column="1" Text="{x:Bind NewLineNumber}" FontFamily="Consolas" FontSize="11" Opacity="0.5" HorizontalAlignment="Right" VerticalAlignment="Center" Padding="0,0,6,0" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                <TextBlock Grid.Column="2" Text="{x:Bind Type, Converter={StaticResource DiffPrefixConverter}}" FontFamily="Consolas" FontSize="11" FontWeight="{x:Bind Type, Converter={StaticResource DiffLineTypeToFontWeightConverter}}" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.7"/>
                <TextBlock Grid.Column="3" Text="{x:Bind Content}" FontFamily="Consolas" FontSize="11" TextWrapping="NoWrap" FontWeight="{x:Bind Type, Converter={StaticResource DiffLineTypeToFontWeightConverter}}" Foreground="{x:Bind Type, Converter={StaticResource DiffLineTypeToForegroundConverter}}" VerticalAlignment="Center"/>
            </Grid>
        </DataTemplate>

    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sessions List -->
        <Grid Grid.Column="0" BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}" BorderThickness="0,0,1,0" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Padding="16,16,16,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Sessions" Style="{StaticResource TitleTextBlockStyle}" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Command="{x:Bind ViewModel.RefreshAllDataCommand, Mode=OneWay}" ToolTipService.ToolTip="Refresh All (Clear Cache)" Background="Transparent" BorderThickness="0">
                    <SymbolIcon Symbol="Refresh"/>
                </Button>
            </Grid>

            <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Sessions}"
                      SelectedItem="{x:Bind ViewModel.SelectedSession, Mode=TwoWay}"
                      ItemContainerStyle="{StaticResource SessionItemStyle}">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:Session">
                        <Grid Padding="14,10" RowSpacing="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="{x:Bind Title, Mode=OneWay}" Style="{StaticResource BodyStrongTextBlockStyle}" MaxLines="1" TextTrimming="CharacterEllipsis" FontSize="14"/>
                            <TextBlock Grid.Row="1" Text="{x:Bind Prompt, Mode=OneWay}" Style="{StaticResource CaptionTextBlockStyle}" MaxLines="1" TextTrimming="CharacterEllipsis" Opacity="0.6" FontSize="12"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- Session Detail / Chat -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Select a session to start"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="{x:Bind ViewModel.SelectedSession, Mode=OneWay, Converter={StaticResource InvertedNullToVisibilityConverter}}"
                       Style="{StaticResource TitleTextBlockStyle}"/>

            <Grid Grid.Row="0" Visibility="{x:Bind ViewModel.SelectedSession, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Padding="16,12" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}" Spacing="8">
                    <TextBlock Text="{x:Bind ViewModel.SelectedSession.Title, Mode=OneWay}" Style="{StaticResource SubtitleTextBlockStyle}"/>

                    <StackPanel Orientation="Horizontal" Spacing="4" Visibility="{x:Bind ViewModel.SelectedSession.SourceContext.StartingBranch, Mode=OneWay, Converter={StaticResource StringToVisibilityConverter}}">
                        <SymbolIcon Symbol="Map" Foreground="{ThemeResource SystemAccentColor}" Opacity="0.7"/>
                        <TextBlock Text="{x:Bind ViewModel.SelectedSession.SourceContext.StartingBranch, Mode=OneWay}" Style="{StaticResource CaptionTextBlockStyle}" VerticalAlignment="Center" Opacity="0.7"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Approve Plan"
                                Visibility="{x:Bind ViewModel.SelectedSession.PendingPlan, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"
                                Command="{x:Bind ViewModel.ApprovePlanCommand}"
                                Style="{StaticResource AccentButtonStyle}"/>

                        <Button Command="{x:Bind ViewModel.CopySessionJsonCommand}"
                                ToolTipService.ToolTip="Copy Session JSON"
                                Background="Transparent" BorderThickness="0">
                            <SymbolIcon Symbol="Copy"/>
                        </Button>
                    </StackPanel>
                </StackPanel>

                <TabView Grid.Row="1" IsAddTabButtonVisible="False" TabWidthMode="Equal" Padding="8,4,8,0">
                    <TabViewItem Header="Chat" IsClosable="False">
                         <ListView x:Name="ChatListView"
                                   ItemsSource="{x:Bind ViewModel.Activities}"
                                   SelectionMode="None"
                                   Padding="0,10"
                                   ItemTemplateSelector="{StaticResource ChatActivityTemplateSelector}">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="MinHeight" Value="0"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,1"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                        </ListView>
                    </TabViewItem>
                    <TabViewItem Header="Diff" IsClosable="False" Visibility="{x:Bind ViewModel.AggregatePatch, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                        <Grid Background="{ThemeResource SolidBackgroundFillColorBaseBrush}">
                            <ListView ItemsSource="{x:Bind ViewModel.FlattenedDiff}"
                                      ItemTemplate="{StaticResource DiffDisplayItemTemplate}"
                                      SelectionMode="None">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="MinHeight" Value="0"/>
                                        <Setter Property="Padding" Value="0"/>
                                    </Style>
                                </ListView.ItemContainerStyle>
                            </ListView>
                        </Grid>
                    </TabViewItem>
                </TabView>
            </Grid>

            <!-- Chat Input -->
            <Grid Grid.Row="1" Padding="16" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                  Visibility="{x:Bind ViewModel.SelectedSession, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" PlaceholderText="Message Jules..."
                         Text="{x:Bind ViewModel.ChatInput, Mode=TwoWay}"
                         AcceptsReturn="True" MaxHeight="120"
                         CornerRadius="8"/>
                <Button Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Bottom"
                        Command="{x:Bind ViewModel.SendMessageCommand}"
                        Style="{StaticResource AccentButtonStyle}"
                        CornerRadius="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Send"/>
                        <TextBlock Text="Send"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Grid>
    </Grid>
</Page>

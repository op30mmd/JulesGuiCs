<Page x:Class="JulesClient.Views.SessionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:JulesClient.Models"
    xmlns:vm="using:JulesClient.ViewModels"
    xmlns:converters="using:JulesClient.Services"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <converters:OriginatorToAlignmentConverter x:Key="OriginatorToAlignmentConverter"/>
        <converters:OriginatorToColorConverter x:Key="OriginatorToColorConverter"/>
        <converters:Base64ToImageSourceConverter x:Key="Base64ToImageSourceConverter"/>
        <converters:InvertedNullToVisibilityConverter x:Key="InvertedNullToVisibilityConverter"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <converters:CollectionToVisibilityConverter x:Key="CollectionToVisibilityConverter"/>
        <converters:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <converters:StringToBooleanConverter x:Key="StringToBooleanConverter"/>

        <DataTemplate x:Key="ProgressUpdatedTemplate" x:DataType="models:ProgressUpdated">
            <StackPanel>
                <TextBlock Text="{x:Bind Title, Mode=OneWay}" FontWeight="Bold" TextWrapping="WrapWholeWords"/>
                <TextBlock converters:MarkdownHelper.Text="{x:Bind Description, Mode=OneWay}"
                           TextWrapping="WrapWholeWords" Opacity="0.9"
                           Visibility="{x:Bind Description, Converter={StaticResource StringToVisibilityConverter}, Mode=OneWay}"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="PlanGeneratedTemplate" x:DataType="models:Plan">
            <StackPanel>
                <TextBlock Text="New Plan Proposed" FontWeight="Bold" Foreground="{ThemeResource SystemAccentColor}"/>
                <TextBlock Text="{x:Bind Title, Mode=OneWay}" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                <TextBlock converters:MarkdownHelper.Text="{x:Bind Description, Mode=OneWay}" TextWrapping="WrapWholeWords" Opacity="0.9"/>

                <ItemsControl ItemsSource="{x:Bind Steps, Mode=OneWay}" Margin="0,10,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:PlanStep">
                            <StackPanel Margin="0,4" Spacing="2">
                                <TextBlock Text="{x:Bind Title, Mode=OneWay}" FontWeight="SemiBold" FontSize="13"/>
                                <TextBlock converters:MarkdownHelper.Text="{x:Bind Description, Mode=OneWay}" FontSize="12" Opacity="0.8"
                                           Visibility="{x:Bind Description, Converter={StaticResource StringToVisibilityConverter}, Mode=OneWay}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="ArtifactsTemplate" x:DataType="models:Artifact">
            <StackPanel Margin="0,8,0,0" Padding="8" Background="{ThemeResource SystemControlBackgroundBaseLowBrush}" CornerRadius="4">
                <StackPanel Visibility="{x:Bind BashOutput, Converter={StaticResource NullToVisibilityConverter}}">
                    <TextBlock Text="{x:Bind BashOutput.Command, Mode=OneWay}" FontFamily="Consolas" Opacity="0.7" Visibility="{x:Bind BashOutput.Command, Converter={StaticResource StringToVisibilityConverter}, Mode=OneWay}"/>
                    <TextBlock Text="{x:Bind BashOutput.Output, Mode=OneWay}" FontFamily="Consolas" TextWrapping="Wrap" Margin="0,4"/>
                    <TextBlock Text="{x:Bind BashOutput.ExitCode, Mode=OneWay}" Style="{StaticResource CaptionTextBlockStyle}" HorizontalAlignment="Right"/>
                </StackPanel>

                <StackPanel Visibility="{x:Bind ChangeSet, Converter={StaticResource NullToVisibilityConverter}}">
                    <TextBlock Text="Code Changes Applied" FontWeight="Bold"/>
                    <TextBlock converters:MarkdownHelper.Text="{x:Bind ChangeSet.GitPatch.SuggestedCommitMessage, Mode=OneWay}" TextWrapping="Wrap" Opacity="0.8" Visibility="{x:Bind ChangeSet.GitPatch.SuggestedCommitMessage, Converter={StaticResource StringToVisibilityConverter}, Mode=OneWay}"/>
                </StackPanel>

                <Image Source="{x:Bind Media.Data, Converter={StaticResource Base64ToImageSourceConverter}, Mode=OneWay}"
                        Visibility="{x:Bind Media, Converter={StaticResource NullToVisibilityConverter}}"
                        MaxHeight="300" Stretch="Uniform"/>
            </StackPanel>
        </DataTemplate>

    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sessions List -->
        <Grid Grid.Column="0" BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}" BorderThickness="0,0,1,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Padding="12" Spacing="10">
                <TextBlock Text="Sessions" Style="{StaticResource TitleTextBlockStyle}"/>
                <Button Command="{x:Bind ViewModel.LoadSessionsCommand}">
                    <SymbolIcon Symbol="Refresh"/>
                </Button>
            </StackPanel>

            <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Sessions}"
                      SelectedItem="{x:Bind ViewModel.SelectedSession, Mode=TwoWay}">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:Session">
                        <StackPanel Padding="12">
                            <TextBlock Text="{x:Bind Title, Mode=OneWay}" Style="{StaticResource BodyStrongTextBlockStyle}" MaxLines="1" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{x:Bind Prompt, Mode=OneWay}" Style="{StaticResource CaptionTextBlockStyle}" MaxLines="1" TextTrimming="CharacterEllipsis" Opacity="0.7"/>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- Session Detail / Chat -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Select a session to start"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="{x:Bind ViewModel.SelectedSession, Mode=OneWay, Converter={StaticResource InvertedNullToVisibilityConverter}}"
                       Style="{StaticResource TitleTextBlockStyle}"/>

            <Grid Grid.Row="0" Visibility="{x:Bind ViewModel.SelectedSession, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Padding="16" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}" Spacing="12">
                    <TextBlock Text="{x:Bind ViewModel.SelectedSession.Title, Mode=OneWay}" Style="{StaticResource SubtitleTextBlockStyle}"/>

                    <ItemsControl ItemsSource="{x:Bind ViewModel.SelectedSession.Outputs, Mode=OneWay}"
                                  Visibility="{x:Bind ViewModel.SelectedSession.Outputs, Mode=OneWay, Converter={StaticResource CollectionToVisibilityConverter}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:SessionOutput">
                                <Border Margin="0,4" Padding="12" CornerRadius="8" Background="{ThemeResource AccentFillColorDefaultBrush}">
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <SymbolIcon Symbol="Link" Foreground="White"/>
                                        <StackPanel>
                                            <TextBlock Text="{x:Bind PullRequest.Title, Mode=OneWay}" FontWeight="Bold" Foreground="White"/>
                                            <HyperlinkButton Content="View Pull Request" NavigateUri="{x:Bind PullRequest.Url, Mode=OneWay}" Padding="0" Foreground="White" Opacity="0.8"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel Orientation="Horizontal" Spacing="10">
                         <Button Content="Approve Plan"
                                 Visibility="{x:Bind ViewModel.SelectedSession.PendingPlan, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}"
                                 Command="{x:Bind ViewModel.ApprovePlanCommand}"
                                 Style="{StaticResource AccentButtonStyle}"/>
                    </StackPanel>
                </StackPanel>

                <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Activities}" SelectionMode="None">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:Activity">
                            <Grid Margin="12,4" HorizontalAlignment="{x:Bind Originator, Converter={StaticResource OriginatorToAlignmentConverter}}">
                                <Border CornerRadius="12" Padding="12" MaxWidth="600"
                                        Background="{x:Bind Originator, Converter={StaticResource OriginatorToColorConverter}}">
                                    <StackPanel Spacing="6">
                                        <TextBlock Text="{x:Bind Originator}" Style="{StaticResource CaptionTextBlockStyle}" FontWeight="Bold" Opacity="0.6"/>

                                        <ContentControl Content="{x:Bind ProgressUpdated}" ContentTemplate="{StaticResource ProgressUpdatedTemplate}"/>
                                        <ContentControl Content="{x:Bind PlanGenerated.Plan}" ContentTemplate="{StaticResource PlanGeneratedTemplate}"/>
                                        <ItemsControl ItemsSource="{x:Bind Artifacts}" ItemTemplate="{StaticResource ArtifactsTemplate}"/>

                                        <TextBlock Text="{x:Bind CreateTime, Mode=OneWay}" Style="{StaticResource CaptionTextBlockStyle}" HorizontalAlignment="Right" Opacity="0.5"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <!-- Chat Input -->
            <Grid Grid.Row="1" Padding="16" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}"
                  Visibility="{x:Bind ViewModel.SelectedSession, Mode=OneWay, Converter={StaticResource NullToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" PlaceholderText="Message Jules..."
                         Text="{x:Bind ViewModel.ChatInput, Mode=TwoWay}"
                         AcceptsReturn="True" MaxHeight="120"
                         CornerRadius="8"/>
                <Button Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Bottom"
                        Command="{x:Bind ViewModel.SendMessageCommand}"
                        Style="{StaticResource AccentButtonStyle}"
                        CornerRadius="8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Send"/>
                        <TextBlock Text="Send"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Grid>
    </Grid>
</Page>

<Page x:Class="JulesClient.Views.SourcesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:JulesClient.Models"
    xmlns:vm="using:JulesClient.ViewModels"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Spacing="10" Grid.Row="0">
            <TextBlock Text="Sources" Style="{StaticResource TitleTextBlockStyle}"/>
            <TextBlock Text="Connected GitHub Repositories" Style="{StaticResource BodyTextBlockStyle}" Opacity="0.6"/>

            <InfoBar Title="Error" Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                     IsOpen="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource StringToBooleanConverter}}"
                     Severity="Error" Margin="0,10"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,20,0,0">
            <RefreshContainer RefreshRequested="OnRefreshRequested">
                <GridView x:Name="SourcesGrid" ItemsSource="{x:Bind ViewModel.Sources}"
                          SelectionMode="None" IsItemClickEnabled="True"
                          ItemClick="OnSourceClick">
                    <GridView.ItemTemplate>
                        <DataTemplate x:DataType="models:Source">
                            <Border Width="280" Height="120" Padding="20" CornerRadius="8"
                                    Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
                                <StackPanel Spacing="8" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind GitHubRepo.Repo}" Style="{StaticResource SubtitleTextBlockStyle}" MaxLines="1" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{x:Bind GitHubRepo.Owner}" Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.7"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </RefreshContainer>

            <ProgressRing IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>
    </Grid>
</Page>

<Page x:Class="JulesClient.Views.SourcesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:JulesClient.Models"
    xmlns:vm="using:JulesClient.ViewModels"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="20" Margin="0,0,0,20">
            <TextBlock Text="Sources" Style="{StaticResource TitleTextBlockStyle}"/>
            <Button Command="{x:Bind ViewModel.LoadSourcesCommand}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <SymbolIcon Symbol="Refresh"/>
                    <TextBlock Text="Refresh"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <ProgressRing Grid.Row="1" IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                      HorizontalAlignment="Center" VerticalAlignment="Center"/>

        <TextBlock Grid.Row="1" Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                   Foreground="Red" Visibility="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource StringToVisibilityConverter}}"
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>

        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Sources}"
                  Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource InvertedBooleanToVisibilityConverter}}">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:Source">
                    <Grid Padding="12" BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}" BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{x:Bind Name}" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                            <TextBlock Text="{x:Bind GitHubSource.Repo}" Style="{StaticResource CaptionTextBlockStyle}"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="New Session" Click="OnNewSessionClick" Tag="{x:Bind}"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <ContentDialog x:Name="CreateSessionDialog" Title="Create New Session"
                       PrimaryButtonText="Create" CloseButtonText="Cancel"
                       DefaultButton="Primary">
            <StackPanel Spacing="10" Margin="0,10,0,0">
                <TextBlock Text="Enter prompt for the new session:"/>
                <TextBox x:Name="PromptTextBox" AcceptsReturn="True" Height="100"/>
            </StackPanel>
        </ContentDialog>
    </Grid>
</Page>

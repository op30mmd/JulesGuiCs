<Window x:Class="JulesClient.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Jules Client">

    <Grid>
        <NavigationView x:Name="Nav" PaneDisplayMode="Left">
            <NavigationView.MenuItems>
                <!-- Sources -->
                <NavigationViewItem Content="Sources" Tag="Sources">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Folder"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <!-- Sessions - using 'Message' instead of invalid 'Chat' -->
                <NavigationViewItem Content="Sessions" Tag="Sessions">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Message"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <!-- Settings -->
                <NavigationViewItem Content="Settings" Tag="Settings">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Setting"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            <Frame x:Name="ContentFrame"/>
        </NavigationView>
    </Grid>
</Window>

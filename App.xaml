<Application x:Class="JulesClient.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:svc="using:JulesClient.Services">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            <svc:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <svc:InvertedBooleanToVisibilityConverter x:Key="InvertedBooleanToVisibilityConverter"/>
            <svc:InvertedNullToVisibilityConverter x:Key="InvertedNullToVisibilityConverter"/>
            <svc:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
            <svc:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
